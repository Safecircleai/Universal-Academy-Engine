# Universal Academy Engine — Environment Configuration
# -------------------------------------------------------
# Copy this file to .env for local dev.
# On Railway: set these as Railway environment variables (not a .env file).
# -------------------------------------------------------

# Application
APP_NAME="Universal Academy Engine"
DEBUG=false

# ------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------

# LOCAL DEV (SQLite — no install required):
DATABASE_URL="sqlite+aiosqlite:///database/uae.db"
DATABASE_SYNC_URL="sqlite:///database/uae.db"

# PRODUCTION (PostgreSQL on Railway):
# Railway auto-injects DATABASE_URL when you attach a Postgres plugin.
# SQLAlchemy requires driver-specific prefixes — add them manually:
#
#   Async (asyncpg):  postgresql+asyncpg://user:pass@host:5432/railway
#   Sync  (psycopg2): postgresql+psycopg2://user:pass@host:5432/railway
#
# In Railway → your service → Variables, set:
# DATABASE_URL="postgresql+asyncpg://user:pass@host.railway.internal:5432/railway"
# DATABASE_SYNC_URL="postgresql+psycopg2://user:pass@host.railway.internal:5432/railway"
#
# You can copy the connection string from Railway's Postgres plugin
# (Data tab → Connection string) and just swap the scheme prefix.

# ------------------------------------------------------------------
# AWS S3 (source document storage)
# ------------------------------------------------------------------
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="uae-source-documents"

# ------------------------------------------------------------------
# API
# ------------------------------------------------------------------
API_HOST="0.0.0.0"
API_PORT=8000

# Railway binds to $PORT automatically. Your start command should use it:
#   uvicorn main:app --host 0.0.0.0 --port $PORT

# ------------------------------------------------------------------
# GOVERNANCE
# ------------------------------------------------------------------
DEFAULT_CONFIDENCE_THRESHOLD=0.75
REQUIRE_HUMAN_REVIEW_ABOVE_CONFIDENCE=0.95
AUTO_DEPRECATE_AFTER_DAYS=730

# ------------------------------------------------------------------
# NODE IDENTITY (federation)
# ------------------------------------------------------------------
NODE_NAME="cfrs_academy"
NODE_TYPE="vocational_academy"

# ------------------------------------------------------------------
# v3 AUTH
# ------------------------------------------------------------------
# Set UAE_AUTH_ENABLED=false for development only
UAE_AUTH_ENABLED=true

# JWT secret — minimum 32 bytes of random entropy
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
UAE_JWT_SECRET=change-me-in-production-32-bytes-minimum

# API Keys — JSON array of key definitions
# UAE_API_KEYS='[{"key":"your-admin-key","role":"admin","name":"admin"},{"key":"fed-key","role":"federation_node","name":"peer-node-b","node_id":"node-b-id"}]'
UAE_API_KEYS=

# For quick dev testing (only used when UAE_API_KEYS is empty)
UAE_DEV_API_KEY=dev-admin-key-change-me

# ------------------------------------------------------------------
# v3 KEY MANAGEMENT
# ------------------------------------------------------------------
# For production, set UAE_NODE_PRIVATE_KEY and UAE_NODE_PUBLIC_KEY
# to PEM-encoded RSA key pair (keep private key secret!)
# Generate keys:
#   openssl genrsa -out node_private.pem 2048
#   openssl rsa -in node_private.pem -pubout -out node_public.pem
UAE_NODE_PRIVATE_KEY=
UAE_NODE_PUBLIC_KEY=
UAE_NODE_KEY_ALGORITHM=RSA-SHA256
UAE_NODE_KEY_ID=node-default
UAE_NODE_KEY_VERSION=v1

# ------------------------------------------------------------------
# v3 FEDERATION TRANSPORT
# ------------------------------------------------------------------
UAE_FEDERATION_REPLAY_WINDOW_SECS=300
UAE_FEDERATION_MAX_RETRIES=3
UAE_FEDERATION_TIMEOUT_SECS=10.0

# ------------------------------------------------------------------
# v3 LLM (agent workers)
# ------------------------------------------------------------------
# Backend: "stub" (no API calls, for testing) | "anthropic" | "openai"
UAE_LLM_BACKEND=stub
UAE_LLM_MODEL_ID=claude-sonnet-4-6
UAE_LLM_MAX_TOKENS=2048
# UAE_LLM_API_KEY=   # or set ANTHROPIC_API_KEY / OPENAI_API_KEY

# ------------------------------------------------------------------
# v3 STORAGE
# ------------------------------------------------------------------
UAE_STORAGE_DIR=./storage
# UAE_IPFS_API_URL=http://localhost:5001  # only if using real IPFS

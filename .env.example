# Universal Academy Engine — Environment Configuration
# Copy this to .env and adjust as needed

# Application
APP_NAME="Universal Academy Engine"
DEBUG=false

# Database (SQLite default for development)
DATABASE_URL="sqlite+aiosqlite:///database/uae.db"
DATABASE_SYNC_URL="sqlite:///database/uae.db"

# For PostgreSQL (production):
# DATABASE_URL="postgresql+asyncpg://user:password@localhost/uae_db"
# DATABASE_SYNC_URL="postgresql+psycopg2://user:password@localhost/uae_db"

# API
API_HOST="0.0.0.0"
API_PORT=8000

# Governance
DEFAULT_CONFIDENCE_THRESHOLD=0.75
REQUIRE_HUMAN_REVIEW_ABOVE_CONFIDENCE=0.95
AUTO_DEPRECATE_AFTER_DAYS=730
